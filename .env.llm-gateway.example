# Copy this file to .env and adjust the paths for your machine.
SYMPHONY_CONTROL_ROOT=/absolute/path/to/symphony-go
SYMPHONY_WORKSPACE_ROOT=/absolute/path/to/symphony-workspaces
SYMPHONY_WORKSPACE_BASELINE_DIR=/absolute/path/to/llm-gateway
SYMPHONY_LOCAL_INBOX_DIR=./local_tasks/inbox
SYMPHONY_LOCAL_STATE_DIR=./local_tasks/state
SYMPHONY_LOCAL_ARCHIVE_DIR=./local_tasks/archive
SYMPHONY_LOCAL_RESULTS_DIR=./local_tasks/results
SYMPHONY_SERVER_AUTH_USERNAME=
SYMPHONY_SERVER_AUTH_PASSWORD=
SYMPHONY_HTTP_PORT=8080
CODEX_INSTALL_COMMAND=
SOURCE_REPO_URL=file:///absolute/path/to/llm-gateway
SOURCE_REPO_REF=main
